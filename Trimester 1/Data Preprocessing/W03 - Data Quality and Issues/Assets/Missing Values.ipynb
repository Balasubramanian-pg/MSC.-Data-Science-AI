    "axes[1].axvline(imputed_age_mean.mean(), color='red', linestyle='--', linewidth=2, label=f'Mean: {imputed_age_mean.mean():.1f}')\n",
    "axes[1].set_xlabel('Age')\n",
    "axes[1].set_ylabel('Frequency')\n",
    "axes[1].set_title('Mean Imputed Age Distribution')\n",
    "axes[1].legend()\n",
