  "core_functions": {
    "regplot": {
      "level": "Axes-level",
      "description": "Plots relationship between X and Y with a superimposed regression line. Flexible regarding data format.",
      "syntax": "sns.regplot(data=df, x='column_x', y='column_y')"
    },
    "lmplot": {
      "level": "Figure-level",
      "description": "More flexible than regplot; requires X and Y as string column references. Supports additional dimensions via parameters.",
      "syntax": "sns.lmplot(data=df, x='column_x', y='column_y')"
    }
  },
  "key_parameters_and_customization": {
    "hue": "Adds a secondary categorical dimension via color (supports multiple regression lines in one plot).",
    "col": "Facets data into separate columns for different categories.",
    "row": "Facets data into separate rows for different categories.",
    "order": "Specifies the degree of the polynomial for non-linear fits (e.g., order=2 for parabolic shapes).",
    "ci": "Controls the confidence interval band (e.g., ci=None removes the shading)."
  },
  "analytical_concepts": {
    "regression_modeling": "A statistical technique to determine the relationship between a dependent variable (e.g., tip amount) and an independent variable (e.g., total bill).",
    "anscombes_quartet": "A collection of four datasets with similar aggregate statistics (mean, median) but very different underlying distributions and patterns, emphasizing the necessity of visualization.",
    "model_selection": "Choosing between a linear fit (order=1) and a polynomial fit (order=2+) based on the visual pattern of the scatter data (e.g., fitting a curve to a parabolic distribution)."
