{
  "course": "Data Visualisation Storytelling",
  "library": "Seaborn",
  "visualization_categories": {
    "categorical_data": {
      "scatter_plots": [
        {
          "type": "strip_plot",
          "description": "Default catplot; represents data as a strip of points.",
          "key_feature": "Uses 'jitter' to prevent overlapping.",
          "command_syntax": "sns.catplot(data=df, x='col', y='val', kind='strip')"
        },
        {
          "type": "swarm_plot",
          "description": "Also known as a bee swarm; adjusts points to prevent overlap.",
          "note": "Best for smaller datasets.",
          "command_syntax": "sns.catplot(data=df, x='col', y='val', kind='swarm')"
        }
      ],
      "distribution_plots": [
        {
          "type": "box_plot",
          "description": "Summarizes distribution, median, quartiles, and outliers.",
          "components": ["median line", "25th/75th percentile", "whiskers", "outliers (dots)"],
          "command_syntax": "sns.catplot(data=df, x='col', y='val', kind='box')"
        },
        {
          "type": "boxen_plot",
          "description": "Modified box plot suitable for very large datasets.",
          "command_syntax": "sns.catplot(data=df, x='col', y='val', kind='boxen')"
        }
      ],
      "estimate_plots": [
        {
          "type": "bar_plot",
          "description": "Shows central tendency (mean) and confidence interval.",
          "command_syntax": "sns.catplot(data=df, x='col', y='val', kind='bar')"
        },
        {
          "type": "point_plot",
          "description": "Connects points to visualize rate of change across categories.",
          "command_syntax": "sns.catplot(data=df, x='col', y='val', kind='point')"
        }
      ]
    },
    "distribution_visualizations": {
      "univariate": {
        "type": "histogram",
        "description": "Shows distribution of a single variable.",
        "key_parameters": ["bins", "discrete=True", "shrink"],
        "command_syntax": "sns.histplot(data=df, x='val')"
      },
      "bivariate": {
        "type": "joint_plot",
        "description": "Combines scatter plot (relationship) with histograms (distributions) on axes.",
        "command_syntax": "sns.jointplot(data=df, x='val1', y='val2')"
      },
      "multivariate": {
        "type": "pair_plot",
        "description": "Plots relationships between all numerical variables in a dataset.",
        "command_syntax": "sns.pairplot(data=df)"
      }
    }
  },
  "customization_features": {
    "hue": "Adds a secondary categorical dimension via color.",
    "order": "Allows manual ordering of categories on the axis.",
    "facet_grid": "Visualizes higher dimensions by repeating plots across rows and columns (col, row parameters).",
    "orientation": "Swapping x and y variables changes axis orientation."
  }
}
