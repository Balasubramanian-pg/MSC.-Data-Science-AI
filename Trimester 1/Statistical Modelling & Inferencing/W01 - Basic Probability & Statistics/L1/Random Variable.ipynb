{
  "probability_theory_hierarchy": {
    "level_1": {
      "topic": "Randomness",
      "description": "Uncertainty in outcomes before observation.",
      "examples": [
        "Coin flips",
        "Stock movements",
        "Customer purchases",
        "Weather"
      ]
    },
    "level_2": {
      "topic": "Sample Space",
      "notation": "Ω",
      "definition": "The complete set of all possible outcomes.",
      "examples": {
        "coin_flip": ["H", "T"],
        "two_coin_flips": ["HH", "HT", "TH", "TT"],
        "dice_roll": [1, 2, 3, 4, 5, 6]
      }
    },
    "level_3": {
      "topic": "Events",
      "definition": "Subsets of the sample space.",
      "examples": {
        "even_roll": [2, 4, 6],
        "at_least_one_head": ["HT", "TH", "HH"]
      }
    },
    "level_4": {
      "topic": "Random Variables",
      "notation": "X",
      "formal_definition": "A measurable function mapping outcomes to real numbers.",
      "mapping_example": {
        "experiment": "Two coin flips",
        "mapping": {
          "HH": 2,
          "HT": 1,
          "TH": 1,
          "TT": 0
        }
      }
    },
    "level_5": {
      "topic": "Probability Distributions",
      "definition": "Rules assigning probability across values of a random variable."
    }
  },
  "discrete_distribution_mechanics": {
    "pmf": {
      "name": "Probability Mass Function",
      "notation": "P(X = x)",
      "properties": [
        "0 ≤ P(X=x) ≤ 1",
        "ΣP(X=x)=1"
      ]
    },
    "coin_flip_example": {
      "random_variable": "Number of heads in two flips",
      "distribution": {
        "0": 0.25,
        "1": 0.5,
        "2": 0.25
      }
    },
    "interpretation": {
      "bars": "Probability concentrated at exact points.",
      "geometry": "Probability represented by bar heights."
    }
  },
  "continuous_distribution_mechanics": {
    "pdf": {
      "name": "Probability Density Function",
      "notation": "f(x)",
      "properties": [
        "f(x) ≥ 0",
        "Total area under curve = 1"
      ]
    },
    "critical_principle": {
      "statement": "Probability at a single exact point is zero.",
      "reason": "Infinite possible real values."
    },
    "interval_probability": {
      "formula": "P(a ≤ X ≤ b)=∫[a,b]f(x)dx"
    },
    "geometry": {
      "interpretation": "Probability equals area under the density curve."
    }
  },
  "cdf": {
    "name": "Cumulative Distribution Function",
    "notation": "F(x)",
    "formula": "F(x)=P(X≤x)",
    "properties": [
      "Always between 0 and 1",
      "Monotonically increasing",
      "Works for both discrete and continuous variables"
    ],
    "relationships": {
      "discrete": "Step function",
      "continuous": "Smooth curve"
    }
  },
  "expectation_theory": {
    "conceptual_meaning": "Probability-weighted center of mass.",
    "discrete": {
      "formula": "E[X]=ΣxP(X=x)"
    },
    "continuous": {
      "formula": "E[X]=∫xf(x)dx"
    },
    "geometric_interpretation": "Balance point of uncertainty.",
    "engineering_interpretation": "Long-run equilibrium value."
  },
  "variance_theory": {
    "formula": "Var(X)=E[(X-μ)^2]",
    "interpretation": {
      "low_variance": "Stable predictable system",
      "high_variance": "Noisy uncertain system"
    },
    "mathematical_reason_for_squaring": [
      "Eliminates sign cancellation",
      "Penalizes large deviations",
      "Creates smooth optimization surfaces"
    ],
    "connection_to_ml": {
      "overfitting": "High variance model",
      "underfitting": "High bias model"
    }
  },
  "standard_deviation": {
    "formula": "σ = √Var(X)",
    "purpose": "Convert spread back into original units.",
    "intuition": {
      "small_sigma": "Concentrated data",
      "large_sigma": "Wide dispersion"
    }
  },
  "bernoulli_distribution": {
    "description": "Single binary random experiment.",
    "possible_outcomes": [0, 1],
    "parameter": {
      "p": "Probability of success"
    },
    "mean": "p",
    "variance": "p(1-p)",
    "applications": [
      "Spam detection",
      "Click prediction",
      "Fraud classification"
    ]
  },
  "binomial_distribution": {
    "description": "Sum of n independent Bernoulli variables.",
    "formula": "P(X=k)=C(n,k)p^k(1-p)^(n-k)",
    "mean": "np",
    "variance": "np(1-p)",
    "shape_behavior": {
      "small_p": "Right-skewed",
      "p=0.5": "Symmetric",
      "large_n": "Approaches Gaussian"
    }
  },
  "uniform_distribution": {
    "definition": "All values equally likely over an interval.",
    "pdf": "f(x)=1/(b-a)",
    "applications": [
      "Random initialization",
      "Monte Carlo simulation",
      "Sampling"
    ]
  },
  "normal_distribution": {
    "nickname": "Gaussian Bell Curve",
    "formula": "f(x)=1/(σ√2π)e^(-(x-μ)^2/(2σ^2))",
    "properties": [
      "Symmetric",
      "Mean = Median = Mode",
      "Fully determined by μ and σ"
    ],
    "68_95_99_rule": {
      "1_sigma": "68%",
      "2_sigma": "95%",
      "3_sigma": "99.7%"
    }
  },
  "central_limit_theorem": {
    "statement": "Sample means converge toward a Gaussian distribution.",
    "requirements": [
      "Independent samples",
      "Finite variance"
    ],
    "formula": {
      "sample_mean_mean": "μ",
      "sample_mean_std": "σ/√n"
    },
    "deep_significance": "Explains why Gaussian structure dominates large systems."
