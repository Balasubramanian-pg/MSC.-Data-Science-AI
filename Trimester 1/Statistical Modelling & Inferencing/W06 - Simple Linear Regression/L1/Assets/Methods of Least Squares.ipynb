    "print(f\"Sum of Squared Errors (SSE): {ls_sse:.4f}\")\n",
    "print(f\"\\nThis line minimizes the total squared prediction error.\")\n",
    "\n",
    "# Compare with other lines\n",
    "alternative_lines = [\n",
