  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 13. The Sum of Squared Errors (SSE)\n",
    "\n",
    "The total regression error is measured using the Sum of Squared Errors:\n",
    "\n",
    "SSE = sum(e_i^2)\n",
    "\n",
    "Substituting residual definitions:\n",
    "\n",
    "SSE = sum(y_i - y_hat_i)^2\n",
    "\n",
    "Since y_hat_i = b0 + b1 * x_i, we obtain:\n",
    "\n",
    "SSE = sum(y_i - (b0 + b1 * x_i))^2\n",
    "\n",
    "This equation defines total prediction error as a function of slope and intercept."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate SSE for different lines\n",
    "intercepts_grid = np.linspace(0, 6, 20)\n",
    "slopes_grid = np.linspace(1, 3, 20)\n",
    "\n",
    "sse_grid = np.zeros((len(intercepts_grid), len(slopes_grid)))\n",
    "\n",
    "for i, b0_test in enumerate(intercepts_grid):\n",
    "    for j, b1_test in enumerate(slopes_grid):\n",
    "        pred_test = b0_test + b1_test * df_demo['X']\n",
    "        sse_grid[i, j] = np.sum((df_demo['Y'] - pred_test)**2)\n",
    "\n",
    "plt.figure(figsize=(12, 8))\n",
    "contour = plt.contour(slopes_grid, intercepts_grid, sse_grid, levels=20, cmap='viridis')\n",
    "plt.colorbar(contour, label='SSE')\n",
    "plt.xlabel('Slope (b1)', fontsize=12)\n",
    "plt.ylabel('Intercept (b0)', fontsize=12)\n",
    "plt.title('SSE as a Function of Slope and Intercept', fontsize=14)\n",
    "\n",
    "# Mark minimum\n",
    "min_idx = np.unravel_index(np.argmin(sse_grid), sse_grid.shape)\n",
    "min_intercept = intercepts_grid[min_idx[0]]\n",
    "min_slope = slopes_grid[min_idx[1]]\n",
    "plt.plot(min_slope, min_intercept, 'r*', markersize=15, label=f'Minimum SSE at b0={min_intercept:.2f}, b1={min_slope:.2f}')\n",
    "\n",
    "plt.legend()\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.show()\n",
    "\n",
    "print(f\"Minimum SSE value: {np.min(sse_grid):.2f}\")\n",
    "print(f\"Optimal intercept: {min_intercept:.2f}\")\n",
    "print(f\"Optimal slope: {min_slope:.2f}\")"
   ]
  },
