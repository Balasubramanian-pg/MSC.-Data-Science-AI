    "print(f\"p-value: {model_sm.pvalues[1]:.6f}\")\n",
    "print(f\"95% confidence interval for beta1: [{model_sm.conf_int()[1][0]:.4f}, {model_sm.conf_int()[1][1]:.4f}]\")\n",
    "\n",
    "if model_sm.pvalues[1] < 0.05:\n",
    "    print(\"\\nCONCLUSION: Reject H0 - There is sufficient evidence of a linear relationship.\")\n",
    "else:\n",
    "    print(\"\\nCONCLUSION: Fail to reject H0 - No significant linear relationship detected.\")"
